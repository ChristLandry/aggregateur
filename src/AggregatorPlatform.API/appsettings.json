{
  "_README": "Valeurs de DEVELOPPEMENT uniquement. Regenerez Jwt.Secret, Encryption.Key, Encryption.IV avant tout deploiement (voir README.md > 'Generer une cle AES-256 + IV').",

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQL_SERVER_2022;Database=AggregatorDB;User Id=sa;Password=P@ssw0rd;TrustServerCertificate=true;Encrypt=false;MultipleActiveResultSets=true"
  },

  "Cache": {
    "DefaultTtlSeconds": 300,
    "PartnerTtlSeconds": 300,
    "DashboardTtlSeconds": 30,
    "KycTtlSeconds": 120
  },

  "Jwt": {
    "Secret": "dev_secret_a2f8b3c9e1d7f4a6b8c0e2f4a6b8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2c4",
    "Issuer": "AggregatorPlatform",
    "Audience": "AggregatorClients",
    "ExpiryMinutes": 600,
    "RefreshExpiryDays": 7,
    "ClockSkewSeconds": 30
  },

  "Encryption": {
    "Key": "K2v6YH3p+vQp1xWZxnxJrk9w0HtSk+VyP3yQwO6sMQk=",
    "IV": "Q1xLZ3Wq3R2pV5sN9oQwLg=="
  },

  "Web": {
    "_doc": "Auto-seed du partenaire technique WEB au demarrage. La cle est hashee en BD ; le front la consomme via NEXT_PUBLIC_WEB_PARTNER_APIKEY.",
    "PartnerApiKey": "dev-web-partner-apikey-CHANGE_ME",
    "BaseUrl": "http://localhost:3000"
  },

  "WaveConnector": {
    "_doc": "Facade Aggregator.WaveConnector.Api. ApiKey = valeur du header X-Partner-Id (doit matcher InboundPartnerId:PartnerId du WaveConnector). L'URL de base est prise sur Partner.BaseUrl a chaque appel (pas de BaseUrl global ici).",
    "ApiKey": "dev-wave-inbound-partner"
  },

  "BankConnector": {
    "_doc": "Connecteur bank_connector externe (deploye via Docker, host port 5280). La BaseUrl est lue en priorite sur Partner.BaseUrl a chaque appel ; cette valeur ne sert que de fallback quand Partner.BaseUrl est vide.",
    "BaseUrl": "http://localhost:5280"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5080",
      "http://localhost:5180",
      "https://localhost:44302",
      "https://localhost:44396",
      "http://localhost:3000",
      "http://localhost:4200",
      "http://localhost:5173",
      "https://app.aggregator.local"
    ]
  },

  "RateLimiting": {
    "DefaultPerMinute": 100,
    "BurstSize": 20,
    "EnableGlobalLimiter": true
  },

  "SystemParameters": {
    "DefaultTimeoutMs": 300000,
    "MaxRetryCount": 3,
    "PendingReconciliationMinutes": 30,
    "RateLimitDefault": 100,
    "CachePartnerTtlSeconds": 300,
    "CacheDashboardTtlSeconds": 30,
    "CacheKycTtlSeconds": 120,
    "LogRetentionDays": 90,
    "WebhookMaxAttempts": 3,
    "ReconciliationIntervalMinutes": 5,
    "WebhookDispatchIntervalSeconds": 30
  },

  "Polly": {
    "Retry": {
      "Count": 3,
      "BackoffSeconds": [ 1, 2, 4 ]
    },
    "CircuitBreaker": {
      "FailureThreshold": 5,
      "DurationOfBreakSeconds": 60
    },
    "HttpTimeoutSeconds": 300
  },

  "Swagger": {
    "Enabled": true,
    "Title": "Aggregator Platform API",
    "Version": "v1",
    "ContactEmail": "dev@aggregator.local"
  },

  "Hsts": {
    "MaxAgeDays": 365,
    "IncludeSubDomains": true,
    "Preload": true
  },

  "TwoFactor": {
    "Issuer": "AggregatorPlatform",
    "RequiredForRoles": [ "Admin", "SuperAdmin" ],
    "ValidWindowSteps": 2
  },

  "SeedAdmin": {
    "Username": "superadmin",
    "Email": "superadmin@aggregator.local",
    "DefaultPassword": "ChangeMe123!"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{RequestId}] [{PartnerId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}

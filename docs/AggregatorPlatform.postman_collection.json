            "url": { "raw": "{{baseUrl}}/api/v1/wallet/debit", "host": ["{{baseUrl}}"], "path": ["api","v1","wallet","debit"] },
            "body": { "mode": "raw", "raw": "{\n  \"partnerTransactionRef\": \"WAL-DEBIT-{{$timestamp}}\",\n  \"bankAccount\": \"{{bankAccount}}\",\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"subscriptionId\": \"{{subscriptionId}}\",\n  \"amount\": 2500,\n  \"currency\": \"XOF\",\n  \"description\": \"Wallet debit test\"\n}", "options": {"raw":{"language":"json"}} }
          }
        },
        {
          "name": "Wallet credit",
          "request": {
            "method": "POST",
            "header": [ { "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/v1/wallet/credit", "host": ["{{baseUrl}}"], "path": ["api","v1","wallet","credit"] },
            "body": { "mode": "raw", "raw": "{\n  \"partnerTransactionRef\": \"WAL-CREDIT-{{$timestamp}}\",\n  \"bankAccount\": \"{{bankAccount}}\",\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"subscriptionId\": \"{{subscriptionId}}\",\n  \"amount\": 7500,\n  \"currency\": \"XOF\",\n  \"description\": \"Wallet credit test\"\n}", "options": {"raw":{"language":"json"}} }
          }
        },
        {
          "name": "Wallet cancel",
          "request": {
            "method": "POST",
            "header": [ { "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/v1/wallet/cancel", "host": ["{{baseUrl}}"], "path": ["api","v1","wallet","cancel"] },
            "body": { "mode": "raw", "raw": "{\n  \"partnerTransactionRef\": \"WAL-CANCEL-{{$timestamp}}\",\n  \"originalExternalRef\": \"{{externalRef}}\"\n}", "options": {"raw":{"language":"json"}} }
          }
        },
        {
          "name": "Wallet link",
          "request": {
            "method": "POST",

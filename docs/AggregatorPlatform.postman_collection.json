            "body": { "mode": "raw", "raw": "{\n  \"name\": \"BankDebit standard XOF\",\n  \"partnerId\": null,\n  \"transactionType\": 0,\n  \"transactionSide\": 0,\n  \"channel\": 0,\n  \"priority\": 100,\n  \"description\": \"Schema BankDebit\",\n  \"lines\": [\n    { \"lineOrder\": 1, \"accountCode\": \"411\", \"accountType\": 0, \"accountExpression\": null, \"side\": 0, \"amountFormula\": \"AMOUNT\", \"label\": \"Debit compte client\", \"code\": \"CLI\", \"exploitant\": \"AU\", \"isFee\": false, \"isConditional\": false, \"condition\": null },\n    { \"lineOrder\": 2, \"accountCode\": \"70-FEE\", \"accountType\": 0, \"accountExpression\": null, \"side\": 1, \"amountFormula\": \"AMOUNT * 0.05\", \"label\": \"Commission\", \"code\": \"FEE\", \"exploitant\": \"AU\", \"isFee\": true, \"isConditional\": false, \"condition\": null },\n    { \"lineOrder\": 3, \"accountCode\": \"707\", \"accountType\": 0, \"accountExpression\": null, \"side\": 1, \"amountFormula\": \"L1 - L2\", \"label\": \"Vente nette\", \"code\": \"INTEG\", \"exploitant\": \"AU\", \"isFee\": false, \"isConditional\": false, \"condition\": null }\n  ]\n}", "options": {"raw":{"language":"json"}} }
          },

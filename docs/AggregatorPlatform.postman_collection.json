            "body": { "mode": "raw", "raw": "{\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"partnerTemporalyCode\": \"OTP-{{$timestamp}}\",\n  \"extras\": {}\n}", "options": {"raw":{"language":"json"}} }
          }
        },
        {
          "name": "Wallet debit",
          "request": {
            "method": "POST",
